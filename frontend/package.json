{
  "name": "novaforge",
  "version": "1.0.1",
  "private": true,
  "description": "NovaForge application",
  "scripts": {
    "analyze": "cross-env ANALYZE=1 max build",
    "build": "cross-env UMI_ENV=test max build",
    "deploy": "pnpm run build && pnpm run gh-pages",
    "dev": "pnpm run start:dev",
    "gh-pages": "gh-pages -d dist",
    "postinstall": "max setup",
    "jest": "jest",
    "lint": "pnpm run lint:js && pnpm run lint:prettier && pnpm run tsc",
    "lint-staged": "lint-staged",
    "lint-staged:js": "eslint --ext .js,.jsx,.ts,.tsx ",
    "lint:fix": "eslint --fix --cache --ext .js,.jsx,.ts,.tsx --format=pretty ./src ",
    "lint:js": "eslint --cache --ext .js,.jsx,.ts,.tsx --format=pretty ./src",
    "lint:prettier": "prettier -c --write \"**/**.{js,jsx,tsx,ts,less,md,json}\" --end-of-line auto",
    "openapi": "max openapi",
    "prettier": "prettier -c --write \"**/**.{js,jsx,tsx,ts,less,md,json}\"",
    "preview": "cross-env UMI_ENV=dev REACT_APP_ENV=dev COMPRESS=none pnpm run build && max preview --port 8000",
    "record": "cross-env NODE_ENV=development REACT_APP_ENV=test max record --scene=login",
    "serve": "umi-serve",
    "start": "cross-env UMI_ENV=dev max dev",
    "start:dev": "cross-env REACT_APP_ENV=dev MOCK=none UMI_ENV=dev max dev",
    "start:no-mock": "cross-env MOCK=none UMI_ENV=dev max dev",
    "start:test": "cross-env REACT_APP_ENV=test MOCK=none UMI_ENV=test max dev",
    "test": "jest",
    "test:coverage": "pnpm run jest -- --coverage",
    "test:update": "pnpm run jest -- -u",
    "tsc": "tsc --noEmit"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": "pnpm run lint-staged:js",
    "**/*.{js,jsx,tsx,ts,less,md,json}": [
      "prettier --write"
    ]
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 10"
  ],
  "dependencies": {
    "@ant-design/icons": "^4.8.3",
    "@ant-design/plots": "^2.6.8",
    "@ant-design/pro-components": "^2.8.10",
    "@antv/l7-react": "^2.4.3",
    "@apollo/client": "^3.14.1",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@uiw/react-codemirror": "^4.25.9",
    "@umijs/route-utils": "^2.2.2",
    "@wangliang139/klinecharts-pro": "^0.2.29",
    "antd": "^5.29.3",
    "antd-style": "^3.7.1",
    "apollo-upload-client": "^18.0.1",
    "classnames": "^2.5.1",
    "crypto-js": "^4.2.0",
    "d3": "^7.9.0",
    "d3-scale": "^4.0.2",
    "dayjs": "^1.11.20",
    "decimal.js": "^10.6.0",
    "dompurify": "^3.3.3",
    "elliptic": "^6.6.1",
    "graphql": "^16.13.2",
    "graphql-ws": "^6.0.8",
    "highlight.js": "^11.11.1",
    "http-parser-js": "^0.5.10",
    "jsencrypt": "^3.5.4",
    "klinecharts": "10.0.0-beta1",
    "lightweight-charts": "^4.2.3",
    "lodash": "^4.18.1",
    "marked": "^13.0.3",
    "mermaid": "^11.14.0",
    "moment": "^2.30.1",
    "numeral": "^2.0.6",
    "omit.js": "^2.0.2",
    "pako": "^2.1.0",
    "papaparse": "^5.5.3",
    "rc-menu": "^9.16.1",
    "rc-util": "^5.44.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-overlay": "6.0.9",
    "react-helmet-async": "^1.3.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "2.13.0-alpha.4",
    "rehype-highlight": "^7.0.2",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "to-json-schema": "^0.2.5",
    "uuid": "^10.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ant-design/pro-cli": "^3.4.0",
    "@eslint/js": "^9.39.4",
    "@iconify-json/ant-design": "1.2.5",
    "@iconify-json/fluent": "1.2.34",
    "@iconify-json/ri": "1.2.6",
    "@testing-library/react": "^13.4.0",
    "@types/crypto-js": "^4.2.2",
    "@types/elliptic": "^6.4.18",
    "@types/express": "^4.17.25",
    "@types/history": "^4.7.11",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.24",
    "@types/pako": "^2.0.4",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/react-helmet": "^6.1.11",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/to-json-schema": "^0.2.4",
    "@types/uuid": "^10.0.0",
    "@umijs/fabric": "^2.14.1",
    "@umijs/lint": "^4.6.40",
    "@umijs/max": "^4.6.40",
    "cross-env": "^7.0.3",
    "express": "^4.22.1",
    "gh-pages": "^3.2.3",
    "globals": "^16.5.0",
    "husky": "^7.0.4",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^10.5.4",
    "mockjs": "^1.1.0",
    "prettier": "^2.8.8",
    "react-dev-inspector": "^1.9.0",
    "swagger-ui-dist": "^4.19.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "umi-presets-pro": "^2.0.3",
    "umi-serve": "^1.9.11"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
